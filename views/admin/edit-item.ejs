<!DOCTYPE html>
<html lang="vi">
<head>
    <title>Sửa Sản phẩm</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />

</head>
<body>
    <%- include('../partials/header') %>
    <div class="container">
        
        <form class="admin-form" action="/admin/edit-item/<%= itemType %>/<%= item._id %>" method="POST" enctype="multipart/form-data">
            
            <div class="form-group"><label>Tên</label><input type="text" name="name" value="<%= item.name %>" required></div>
            <div class="form-group"><label>Mô tả</label><textarea name="description" required><%= item.description %></textarea></div>
                        <div class="form-group">
                <label>Ảnh sản phẩm hiện tại</label>
                <div>
                    <img src="<%= item.imageUrl %>" alt="Current Image" style="max-width: 200px; display: block; margin-bottom: 10px;">
                </div>
                <label>Thay đổi ảnh (Tùy chọn)</label>
                <input type="file" name="image" accept="image/*" style="border: 1px solid #ddd; padding: 8px; width: 100%;">
            </div>
            <div class="form-group"><label>Giá</label><input type="number" name="price" value="<%= item.price %>" required></div>
            <div class="form-group">
                <label>Số lượng kho</label>
                <input type="number" name="stock" value="<%= item.stock || 0 %>" min="0" required>
            </div>

            <% if (itemType === 'product') { %>
                <div class="form-group"><label>Thương hiệu</label><input type="text" name="brand" value="<%= item.brand %>"></div>
                <div class="form-group"><label>Xuất xứ / Vùng trồng</label><input type="text" name="origin" value="<%= item.origin %>"></div>
                <div class="form-group"><label>Loại vang</label><input type="text" name="type" value="<%= item.type %>"></div>
                <div class="form-group"><label>Năm sản xuất (Vintage)</label><input type="number" name="vintage" value="<%= item.vintage %>"></div>
                <div class="form-group"><label>Giống nho</label><input type="text" name="grape" value="<%= item.grape %>"></div>
                <div class="form-group"><label>Nồng độ cồn (ABV %)</label><input type="number" step="0.1" name="abv" value="<%= item.abv %>"></div>
                <div class="form-group"><label>Vùng làm vang chi tiết</label><input type="text" name="region" value="<%= item.region %>"></div>
                <div class="form-group"><label>Hương vị đặc trưng</label><input type="text" name="tastingNotes" value="<%= item.tastingNotes %>"></div>
                <div class="form-group"><label>Gợi ý kết hợp món ăn</label><input type="text" name="foodPairing" value="<%= item.foodPairing %>"></div>
                <div class="form-group"><label>Dung tích (ml)</label><input type="number" name="volume" value="<%= item.volume %>"></div>
            <% } else if (itemType === 'accessory') { %>
                <div class="form-group"><label>Danh mục phụ kiện</label>
                    <input type="text" name="category" value="<%= item.category %>" readonly>
                    <small>Để thay đổi danh mục, vui lòng xóa và tạo lại sản phẩm.</small>
                </div>
            <% } else if (itemType === 'giftset') { %>
                 <div class="form-group"><label>Danh mục quà tặng</label>
                    <input type="text" name="category" value="<%= item.category %>" readonly>
                    <br><br>
                    <small>Để thay đổi danh mục, vui lòng xóa và tạo lại sản phẩm.</small>
                </div>
            <% } %>

            <button type="submit">Cập nhật Sản phẩm</button>
        </form>
    </div>
</body>
</html>