<!DOCTYPE html>
<html lang="vi">
<head>
    <title>Nhập Kho Sản Phẩm - Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    <style>
        .main-header { position: relative !important; z-index: 9999 !important; }
        .user-dropdown { z-index: 10000 !important; }

        .import-container {
            max-width: 600px;
            background: #ffffff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            margin: 20px auto;
            border: 1px solid #e0e0e0;
        }
        .import-container h2 {
            color: #333;
            margin-bottom: 25px;
            text-align: center;
            font-size: 1.8rem;
        }
        .import-form .form-group { margin-bottom: 1.5rem; }
        .import-form label {
            display: block; font-weight: 500; margin-bottom: 8px; color: #555;
        }
        .import-form input {
            width: 100%; padding: 12px 15px; border: 1px solid #ccc;
            border-radius: 4px; font-size: 1rem; box-sizing: border-box;
        }
        .import-form input:focus {
            border-color: #c5a47e; outline: none; box-shadow: 0 0 0 2px rgba(197, 164, 126, 0.2);
        }
        .hint-text { display: block; margin-top: 5px; font-size: 0.85rem; color: #888; }
        .btn-import {
            background-color: #28a745; color: white; padding: 12px 30px;
            border: none; border-radius: 5px; cursor: pointer; width: 100%;
            font-size: 1rem; font-weight: bold; transition: background-color 0.3s; margin-top: 10px;
        }
        .btn-import:hover { background-color: #218838; }

        /* --- CSS MỚI CHO Ô TÌM KIẾM SẢN PHẨM --- */
        .searchable-select { position: relative; }
        .searchable-list {
            position: absolute; top: 100%; left: 0; width: 100%;
            max-height: 250px; overflow-y: auto; background: #fff;
            border: 1px solid #c5a47e; border-top: none; border-radius: 0 0 4px 4px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1); z-index: 10;
            display: none; margin: 0; padding: 0; list-style: none;
        }
        .searchable-list li {
            padding: 10px 15px; cursor: pointer; border-bottom: 1px solid #eee; color: #333;
        }
        .searchable-list li:last-child { border-bottom: none; }
        .searchable-list li:hover { background-color: #fdfaf6; color: #c5a47e; }
        .searchable-list li.hidden { display: none; }
    </style>
</head>
<body>
    <%- include('../partials/header') %>
    
    <div class="container" style="margin-top: 20px;">
        <div class="import-container">
            <h2>📦 Nhập Kho Sản Phẩm</h2>
            
            <form action="/admin/import" method="POST" class="import-form" onsubmit="return validateForm()">
                
                <div class="form-group">
                    <label>Tìm & Chọn Sản Phẩm:</label>
                    <div class="searchable-select">
                        <input type="text" id="searchInput" placeholder="Gõ tên sản phẩm để tìm..." autocomplete="off">
                        <input type="hidden" name="itemId" id="itemId" required>
                        
                        <ul class="searchable-list" id="searchList">
                            <% if(items && items.length > 0) { %>
                                <% items.forEach(function(item) { %>
                                    <li data-id="<%= item._id %>" data-name="<%= item.name %>">
                                        <strong><%= item.name %></strong><br>
                                        <small style="color:#777;">Tồn: <%= item.stock %> | Giá: <%= new Intl.NumberFormat('vi-VN').format(item.price) %>đ</small>
                                    </li>
                                <% }); %>
                            <% } else { %>
                                <li style="pointer-events: none; text-align: center;">Chưa có sản phẩm nào</li>
                            <% } %>
                        </ul>
                    </div>
                </div>

                <div class="form-group">
                    <label for="importQuantity">Số lượng nhập:</label>
                    <input type="number" name="importQuantity" id="importQuantity" min="1" required placeholder="Nhập số lượng...">
                </div>

                <div class="form-group">
                    <label for="totalImportCost">Tổng tiền nhập lô này (VNĐ):</label>
                    <input type="number" name="totalImportCost" id="totalImportCost" min="0" required placeholder="Ví dụ: Nhập 10 chai tổng 5000000">
                    <small class="hint-text">Hệ thống sẽ tự động chia đều để tính lại giá vốn bình quân cho sản phẩm.</small>
                </div>

                <button type="submit" class="btn-import">Xác nhận nhập kho</button>
            </form>
        </div>
    </div>

    <script>
        const searchInput = document.getElementById('searchInput');
        const searchList = document.getElementById('searchList');
        const listItems = searchList.querySelectorAll('li[data-id]');
        const hiddenItemId = document.getElementById('itemId');

        // 1. Hiện danh sách khi click vào ô input
        searchInput.addEventListener('focus', function() {
            searchList.style.display = 'block';
        });

        // 2. Lọc sản phẩm theo thời gian thực khi gõ phím
        searchInput.addEventListener('input', function() {
            const filterText = this.value.toLowerCase().trim();
            let hasVisibleItem = false;

            listItems.forEach(li => {
                const itemText = li.textContent.toLowerCase();
                if (itemText.includes(filterText)) {
                    li.classList.remove('hidden');
                    hasVisibleItem = true;
                } else {
                    li.classList.add('hidden');
                }
            });

            searchList.style.display = hasVisibleItem ? 'block' : 'none';
            // Reset dữ liệu nếu người dùng cố tình gõ sai chữ sau khi đã chọn
            hiddenItemId.value = ''; 
        });

        // 3. Khi người dùng click chọn 1 sản phẩm
        listItems.forEach(li => {
            li.addEventListener('click', function() {
                searchInput.value = this.getAttribute('data-name'); // Hiển thị tên
                hiddenItemId.value = this.getAttribute('data-id');  // Lưu ID ẩn
                searchList.style.display = 'none'; // Đóng danh sách
            });
        });

        // 4. Bấm ra ngoài thì đóng danh sách thả xuống
        document.addEventListener('click', function(e) {
            if (!searchInput.contains(e.target) && !searchList.contains(e.target)) {
                searchList.style.display = 'none';
            }
        });

        // 5. Kiểm tra bắt buộc chọn đúng sản phẩm mới cho submit
        function validateForm() {
            if (!hiddenItemId.value) {
                alert("Bạn phải bấm chọn một sản phẩm từ danh sách xổ xuống!");
                searchInput.focus();
                return false;
            }
            return true;
        }
    </script>

    <script src="/js/header.js"></script>
</body>
</html>