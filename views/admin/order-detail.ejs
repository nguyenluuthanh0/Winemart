<!DOCTYPE html>
<html lang="vi">
<head>
    <title>Chi tiết Đơn hàng #<%= order.orderId || order._id.toString().slice(-6).toUpperCase() %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <style>
        .main-header { position: relative !important; z-index: 9999 !important; }
        .user-dropdown { z-index: 10000 !important; }
        .detail-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }
        .info-box {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.05);
        }
        .info-box h3 {
            margin-top: 0;
            border-bottom: 2px solid #ddd;
            padding-bottom: 8px;
            color: #800020;
        }
        .info-box p {
            margin: 10px 0;
            font-size: 14px;
            color: #333;
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>
    
    <div class="container" style="margin-top: 20px; margin-bottom: 5px;">
        <div class="admin-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h1>Chi tiết Đơn hàng: #<%= order.orderId || order._id.toString().slice(-6).toUpperCase() %></h1>
            <a href="/admin/orders" class="btn-edit" style="text-decoration: none; padding: 8px 15px;">← Quay lại danh sách</a>
        </div>

        <div class="detail-grid">
            <div class="info-box">
                <h3><i class="fas fa-file-invoice"></i> Thông tin giao dịch</h3>
                <p><strong>Mã Đơn hàng (Hệ thống):</strong> <%= order._id %></p>
                <p><strong>Mã Giao dịch:</strong> <%= order.orderId || 'N/A' %></p>
                <p><strong>Ngày đặt hàng:</strong> <%= new Date(order.createdAt).toLocaleString('vi-VN') %></p>
                <p><strong>Phương thức thanh toán:</strong> <span style="text-transform: uppercase;"><%= order.paymentMethod %></span></p>
                
                <p><strong>Trạng thái thanh toán:</strong> 
                    <% if (order.paid === true || order.status === 'completed') { %>
                        <span style="font-weight: bold; color: green;">Đã thu tiền thành công</span>
                    <% } else { %>
                        <% if (order.paymentMethod === 'cod') { %>
                            <span style="font-weight: bold; color: #d35400;">Chưa thu tiền (Thanh toán khi nhận hàng)</span>
                        <% } else { %>
                            <span style="font-weight: bold; color: red;">Chưa thanh toán / Lỗi giao dịch</span>
                        <% } %>
                    <% } %>
                </p>
                <% if(order.paidAt) { %>
                    <p><strong>Thời gian thanh toán:</strong> <%= new Date(order.paidAt).toLocaleString('vi-VN') %></p>
                <% } %>
            </div>

            <div class="info-box">
                <h3><i class="fas fa-truck"></i> Thông tin giao hàng</h3>
                <p><strong>Tên người nhận:</strong> <%= order.customerInfo ? order.customerInfo.name : 'Chưa cập nhật' %></p>
                <p><strong>Số điện thoại:</strong> <%= order.customerInfo ? order.customerInfo.phone : 'Chưa cập nhật' %></p>
                <p><strong>Địa chỉ nhận hàng:</strong> <%= order.customerInfo ? order.customerInfo.address : 'Chưa cập nhật' %></p>
                <p><strong>Email khách hàng:</strong> <%= order.customerInfo ? order.customerInfo.email : 'Chưa cập nhật' %></p>
                <p><strong>Ghi chú đơn hàng:</strong> 
                    <span style="font-style: italic; color: #666;">
                        <%= (order.customerInfo && order.customerInfo.notes) ? order.customerInfo.notes : 'Không có ghi chú' %>
                    </span>
                </p>
            </div>
        </div>

        <h2 style="color: #444; font-size: 18px; margin-bottom: 10px;"><i class="fas fa-box-open"></i> Danh sách mặt hàng mua</h2>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Phân loại</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                    <th>Tiền lãi</th>
                </tr>
            </thead>
            <tbody>
                <% if (order.items && order.items.length > 0) { %>
                    <% order.items.forEach(subItem => { %>
                        <tr>
                            <td style="width: 80px; text-align: center;">
                                <img src="<%= subItem.item && subItem.item.image ? subItem.item.image : '/images/logo.png' %>" alt="" style="max-width: 50px; max-height: 50px; object-fit: contain; border-radius: 4px;">
                            </td>
                            <td><strong><%= subItem.item ? subItem.item.name : 'Sản phẩm đã bị xóa khỏi hệ thống' %></strong></td>
                            <td>
                                <span style="background: #eef2f3; padding: 3px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; text-transform: uppercase;">
                                    <% if (subItem.itemModel === 'Product') { %>
                                        Rượu vang
                                    <% } else if (subItem.itemModel === 'Accessory') { %>
                                        Phụ kiện
                                    <% } else if (subItem.itemModel === 'GiftSet') { %>
                                        Quà tặng
                                    <% } else { %>
                                        <%= subItem.itemModel %>
                                    <% } %>
                                </span>
                            </td>
                            <td><%= new Intl.NumberFormat('vi-VN').format(subItem.price) %> ₫</td>
                            <td><%= subItem.quantity %></td>
                            <td style="font-weight: bold; color: #800020;">
                                <%= new Intl.NumberFormat('vi-VN').format(subItem.price * subItem.quantity) %> ₫
                            </td>
                            <td style="font-weight: bold; color: #28a745;">
                                <% let itemProfit = (subItem.price - (subItem.costPrice || 0)) * subItem.quantity; %>
                                + <%= new Intl.NumberFormat('vi-VN').format(itemProfit) %> ₫
                                <div style="font-size: 12px; color: #888; font-weight: normal; margin-top: 4px;">
                                    (Vốn: <%= new Intl.NumberFormat('vi-VN').format(subItem.costPrice || 0) %> ₫)
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="7" style="text-align: center; padding: 15px;">Không tìm thấy thông tin sản phẩm trong đơn.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        <div style="text-align: right; margin-top: 20px; background: #fff; padding: 15px 20px; border-radius: 8px; border: 1px solid #eee;">
            <p style="font-size: 16px; margin: 5px 0;">Tổng số lượng sản phẩm: <strong><%= order.items.reduce((total, item) => total + item.quantity, 0) %></strong></p>
            <h2 style="color: #800020; font-size: 24px; margin: 5px 0;">Tổng giá trị đơn hàng: <%= new Intl.NumberFormat('vi-VN').format(order.amount || order.totalAmount) %> ₫</h2>
            <% 
                let totalOrderProfit = 0;
                if (order.items && order.items.length > 0) {
                    totalOrderProfit = order.items.reduce((sum, item) => sum + ((item.price - (item.costPrice || 0)) * item.quantity), 0);
                }
            %>
            <h2 style="color: #28a745; font-size: 20px; margin: 10px 0 5px 0; border-top: 1px dashed #ccc; padding-top: 10px;">
                Tổng lợi nhuận thu về: <%= new Intl.NumberFormat('vi-VN').format(totalOrderProfit) %> ₫
            </h2>
        </div>
    </div>

    <script src="/js/header.js"></script>
</body>
</html>