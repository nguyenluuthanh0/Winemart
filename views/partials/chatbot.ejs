<button id="chatToggleBtn" class="chat-toggle-btn">💬 Tư vấn AI</button>

<div id="chatContainer" class="chat-container">
    <!-- Nút cầm (ẩn) ở góc trên-trái để kéo dãn khung chat -->
    <div id="chatResizeHandle" style="position: absolute; top: 0; left: 0; width: 25px; height: 25px; cursor: nwse-resize; z-index: 10000; background: transparent;"></div>
    
    <div class="chat-header">
        <span>🍷 Sommelier Winemart</span>
        <button id="chatCloseBtn" class="chat-close-btn">&times;</button>
    </div>
    
    <div id="chatBody" class="chat-body">
        <div class="chat-message bot-message">
            Chào bạn, tôi là chuyên gia AI của Winemart. Bạn muốn tìm loại rượu vang nào hôm nay?
        </div>
    </div>

    <div class="chat-footer">
        <input type="text" id="chatInput" class="chat-input" placeholder="Nhập câu hỏi của bạn...">
        <button id="chatSendBtn" class="chat-send-btn">Gửi</button>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const chatToggleBtn = document.getElementById('chatToggleBtn');
    const chatCloseBtn = document.getElementById('chatCloseBtn');
    const chatContainer = document.getElementById('chatContainer');
    const chatResizeHandle = document.getElementById('chatResizeHandle');

    // Bấm nút mở chat
    chatToggleBtn.addEventListener('click', () => {
        chatContainer.classList.add('show'); // Hiển thị khung chat
        chatToggleBtn.style.display = 'none'; // Ẩn nút tròn đi
    });

    // Bấm dấu X để đóng chat
    chatCloseBtn.addEventListener('click', () => {
        chatContainer.classList.remove('show'); // Ẩn khung chat
        chatToggleBtn.style.display = 'block'; // Hiện lại nút tròn
    });

    // --- Tính năng Kéo dãn khung chat từ góc trên-trái ---
    let isResizing = false;
    let startX, startY, startWidth, startHeight;

    chatResizeHandle.addEventListener('mousedown', (e) => {
        isResizing = true;
        startX = e.clientX;
        startY = e.clientY;
        const rect = chatContainer.getBoundingClientRect();
        startWidth = rect.width;
        startHeight = rect.height;
        document.body.style.userSelect = 'none'; // Chống bôi đen chữ khi kéo
        e.preventDefault();
    });

    document.addEventListener('mousemove', (e) => {
        if (!isResizing) return;
        
        // Vì khung chat cố định ở góc dưới-phải (bottom/right), 
        // việc kéo góc trên-trái ngược hướng chuột sẽ làm tăng kích thước.
        const newWidth = startWidth - (e.clientX - startX);
        const newHeight = startHeight - (e.clientY - startY);
        
        if (newWidth >= 320 && newWidth <= 800) {
            chatContainer.style.width = newWidth + 'px';
        }
        if (newHeight >= 400 && newHeight <= window.innerHeight * 0.85) {
            chatContainer.style.height = newHeight + 'px';
        }
    });

    document.addEventListener('mouseup', () => {
        if (isResizing) {
            isResizing = false;
            document.body.style.userSelect = '';
        }
    });
    // --------------------------------------------------------

    const chatInput = document.getElementById('chatInput');
    const chatSendBtn = document.getElementById('chatSendBtn');
    const chatBody = document.getElementById('chatBody');

    // Hàm phụ trợ: Thêm bong bóng chat vào giao diện
    function appendMessage(sender, text) {
        const msgDiv = document.createElement('div');
        // Phân biệt class của bot và user để lên màu chuẩn xác
        msgDiv.className = `chat-message ${sender === 'user' ? 'user-message' : 'bot-message'}`;
        
        // Dùng innerHTML để đọc được các thẻ <b>, <br> mà Gemini trả về
        msgDiv.innerHTML = text; 
        
        const msgId = 'msg-' + Date.now();
        msgDiv.id = msgId;

        chatBody.appendChild(msgDiv);
        chatBody.scrollTop = chatBody.scrollHeight; // Tự động cuộn xuống tin nhắn mới nhất
        return msgId;
    }

    // Hàm xử lý chính: Gửi dữ liệu lên API
    async function sendMessage() {
        const message = chatInput.value.trim();
        if (!message) return;

        // Hiển thị tin nhắn của khách hàng
        appendMessage('user', message);
        chatInput.value = ''; // Xóa trắng ô nhập liệu

        // Hiển thị trạng thái chờ AI
        const loadingId = appendMessage('bot', '<i>Sommelier đang tìm kiếm trong kho...</i>');

        try {
            // Gửi Request tới route /api/chat mà bạn đã định nghĩa
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ message: message })
            });

            const data = await response.json();

            // Xóa dòng "đang tìm kiếm" và hiển thị câu trả lời của AI
            document.getElementById(loadingId).remove();
            appendMessage('bot', data.reply);

        } catch (error) {
            console.error('Lỗi khi gọi API Chat:', error);
            document.getElementById(loadingId).remove();
            appendMessage('bot', 'Xin lỗi, kết nối đến chuyên gia đang bị gián đoạn. Vui lòng thử lại!');
        }
    }

    // Bắt sự kiện khi click nút Gửi
    chatSendBtn.addEventListener('click', sendMessage);

    // Bắt sự kiện khi khách hàng nhấn phím Enter
    chatInput.addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            sendMessage();
        }
    });
});
</script>